# =============================================================================
# Web image — Vite build served by nginx (mirrors the dev /api proxy)
# =============================================================================
# Multi-stage: build the static React bundle, then serve it from nginx with
# /api proxied to the api service (replacing the Vite dev proxy in production).
# =============================================================================

# ---- Build stage ----
FROM node:22-bookworm-slim AS build
WORKDIR /app

# Native toolchain for any workspace dependency that compiles during npm ci.
RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 make g++ \
  && rm -rf /var/lib/apt/lists/*

# Workspace manifests first for cached installs (devDeps like vite are required).
COPY package.json package-lock.json ./
COPY apps/api/package.json apps/api/
COPY apps/web/package.json apps/web/
COPY apps/cli/package.json apps/cli/
COPY libs/core/package.json libs/core/
COPY libs/config/package.json libs/config/
COPY libs/monday/package.json libs/monday/
COPY libs/query/package.json libs/query/
COPY libs/relationship-map/package.json libs/relationship-map/
COPY libs/template/package.json libs/template/
COPY libs/seed/package.json libs/seed/
RUN npm ci

COPY . .
RUN npm run build -w @case-pipeline/web

# ---- Serve stage ----
FROM nginx:1.27-alpine
COPY apps/web/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/apps/web/dist /usr/share/nginx/html
EXPOSE 80
