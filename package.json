{
  "name": "case-pipeline",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "dev:api": "npm run dev -w @case-pipeline/api",
    "dev:cli": "npm run dev -w @case-pipeline/cli",
    "dev:web": "npm run dev -w @case-pipeline/web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run && npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "preflight": "bash scripts/preflight.sh",
    "seed": "tsx scripts/seed/index.ts",
    "stats": "tsx scripts/export-stats.ts",
    "stats:live": "tsx scripts/export-stats.ts --db=live"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@faker-js/faker": "^10.2.0",
    "better-sqlite3": "^11.10.0",
    "docxtemplater": "^3.67.6",
    "express": "^5.1.0",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.1",
    "pizzip": "^3.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "xlsx": "^0.18.5"
  }
}
