{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      "@case-pipeline/core": ["./libs/core/src/index.ts"],
      "@case-pipeline/core/*": ["./libs/core/src/*"],
      "@case-pipeline/config": ["./libs/config/src/index.ts"],
      "@case-pipeline/config/*": ["./libs/config/src/*"],
      "@case-pipeline/monday": ["./libs/monday/src/index.ts"],
      "@case-pipeline/monday/*": ["./libs/monday/src/*"],
      "@case-pipeline/query": ["./libs/query/src/index.ts"],
      "@case-pipeline/query/*": ["./libs/query/src/*"],
      "@case-pipeline/relationship-map": ["./libs/relationship-map/src/index.ts"],
      "@case-pipeline/relationship-map/*": ["./libs/relationship-map/src/*"],
      "@case-pipeline/template": ["./libs/template/src/index.ts"],
      "@case-pipeline/template/*": ["./libs/template/src/*"],
      "@case-pipeline/seed": ["./libs/seed/src/index.ts"],
      "@case-pipeline/seed/*": ["./libs/seed/src/*"]
    }
  }
}
