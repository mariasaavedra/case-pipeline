# =============================================================================
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Copy this to .env — the sync command loads it via --env-file automatically.
# =============================================================================

# Required: Monday.com API Token (shared service account for sync)
# Get yours at: https://monday.com/developers/apps
# Needed for the live sync (npm run sync:live) and the render pipeline.
MONDAY_API_TOKEN=your_api_token_here

# Monday.com OAuth app — for per-user note attribution
# Create an app at https://monday.com/developers/apps and set the redirect URI to:
#   {API_URL}/api/auth/monday/callback
MONDAY_CLIENT_ID=your_client_id_here
MONDAY_CLIENT_SECRET=your_client_secret_here

# URLs — used for OAuth redirects
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Recommended (production): passphrase to encrypt database backups at rest.
# Backups (live.db, users.db) hold client PII + Monday tokens; when this is set
# they are written as AES-256-GCM `.db.enc` files. WITHOUT it, backups are
# plaintext. Store this key somewhere OTHER than the backups (a lost key means
# lost backups). Restore with: npx tsx scripts/restore-backup.ts <file.db.enc>
# BACKUP_ENCRYPTION_KEY=generate_a_long_random_passphrase

# Recommended (production): passphrase to encrypt per-user secrets at rest.
# Monday.com OAuth tokens (and future per-user credentials) in users.db are
# encrypted column-side (AES-256-GCM) when this is set; WITHOUT it they are
# stored in plaintext (the app warns on boot). Kept separate from
# BACKUP_ENCRYPTION_KEY on purpose. Generate one with: openssl rand -base64 48
# APP_ENCRYPTION_KEY=generate_a_long_random_passphrase

# Optional: re-enable the midnight sync cron (default: OFF).
# `npm run sync:live` calls resetDatabase() — a full DROP — BEFORE it fetches
# anything, so a run interrupted partway leaves an EMPTY database instead of
# yesterday's data, and a single board failing its retries (network timeout)
# silently wipes that board for the day. Until the sync is incremental, run it
# by hand where someone can see it fail.
#
# Safety net (always on): before that DROP, a full sync snapshots the current
# live.db to data/backups/live-presync-<stamp>.db and ABORTS if the snapshot
# fails — so a wipe always has a fallback behind it. Restore is just a file copy
# over data/live.db. The daily 02:30 cron keeps a separate live-<stamp> series.
# NIGHTLY_SYNC=on

# Optional: Which local database the API and tools read from (default: seed)
#   seed → data/seed.db  (Faker.js data, safe to regenerate, used by CI)
#   live → data/live.db  (real Monday.com data, gitignored, local only)
# DB_SOURCE=seed

# Optional: API bind address + port (defaults: 127.0.0.1:3000)
# Locally keep the loopback default — the API is unauthenticated and serves PII.
# In a container behind nginx (no published port) set HOST=0.0.0.0.
# HOST=127.0.0.1
# PORT=3000

# Required: Item ID to process (for main pipeline)
ITEM_ID=your_item_id_here

# Optional: Template to render (default: client_letter)
TEMPLATE_NAME=client_letter

# Optional: Output directory for rendered files (default: output)
OUTPUT_DIR=output

# Optional: Override board IDs from config/boards.yaml
# PROFILES_BOARD_ID=18397286934
# CONTRACTS_BOARD_ID=18397312752

# Optional: Monday.com API version (default: 2024-10)
# See: https://developer.monday.com/api-reference/docs/api-versioning
# MONDAY_API_VERSION=2024-10
