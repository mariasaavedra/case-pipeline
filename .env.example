# =============================================================================
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Bun automatically loads .env files - no dotenv package needed.
# =============================================================================

# Required: Monday.com API Token
# Get yours at: https://monday.com/developers/apps
MONDAY_API_TOKEN=your_api_token_here

# Required: Item ID to process (for main pipeline)
ITEM_ID=your_item_id_here

# Optional: Template to render (default: client_letter)
TEMPLATE_NAME=client_letter

# Optional: Output directory for rendered files (default: output)
OUTPUT_DIR=output

# Optional: Override board IDs from config/boards.yaml
# PROFILES_BOARD_ID=18397286934
# CONTRACTS_BOARD_ID=18397312752

# Optional: Monday.com API version (default: 2024-10)
# See: https://developer.monday.com/api-reference/docs/api-versioning
# MONDAY_API_VERSION=2024-10
